{
    "name": "ysfkc/clickhouse",
    "description": "Lightweight ClickHouse HTTP client with a fluent QueryBuilder and ORM-style base model for PHP 8.1+.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "clickhouse",
        "php",
        "query-builder",
        "http-client",
        "orm",
        "database",
        "analytics"
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^6.0.0|^7.4.5",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ysfkc\\ClickHouse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ysfkc\\ClickHouse\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "suggest": {
        "phalcon/phalcon": "Required only if you use the optional Ysfkc\\ClickHouse\\Logger\\PhalconLoggerAdapter bridge."
    }
}
